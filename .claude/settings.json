{
  "permissions": {
    "allow": [
      "Bash(./mvnw -q -DskipTests compile)",
      "Bash(./mvnw test:*)",
      "Bash(./mvnw spring-boot:run)",
      "Bash(./mvnw clean package -DskipTests)",
      "Bash(docker-compose up -d:*)",
      "Bash(docker-compose ps:*)",
      "Bash(docker-compose logs:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ]
  },
  "env": {
    "SPRING_PROFILES_ACTIVE": "dev"
  }
}
